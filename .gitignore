# Personal data — never commit these
profile.md
fitness.md
races.md
plan_current.md
groups.md
garmin_workouts/upcoming/
garmin_workouts/archive/

# Keep templates and skills
!garmin_workouts/templates/
!CLAUDE.md
!skills_core.md
!skills_garmin.md
!garmin_gen.py
!project_instructions.txt

# Local install path (written by install.ps1, read by sync.ps1)
.install_path

# Claude Desktop config (contains paths/credentials)
claude_desktop_config.json

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# DB — per-user local SQLite + cloud secrets (never commit)
starter_files/db/data.db
starter_files/db/data.db-*
starter_files/db/data_replica.db*
starter_files/db/.env

# Bot secrets — TELEGRAM_BOT_TOKEN + Turso credentials
starter_files/bot/.env

# Python bytecode
__pycache__/
*.pyc
*.pyo

# Auto-generated user-facing files (regenerated from DB by skills)
starter_files/volume_log.md
starter_files/garmin_workouts/gym/gym_log.md

# Streamlit — keep config.toml + secrets.toml.example, hide live secrets + cache
starter_files/.streamlit/secrets.toml
.streamlit/secrets.toml
.streamlit/cache/
