{
  "mcpServers": {
    "strava": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@r-huijts/strava-mcp-server"]
    },
    "memory": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@modelcontextprotocol/server-memory"]
    },
    "filesystem": {
