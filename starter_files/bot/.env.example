## Telegram
# BotFather -> /mybots -> pick bot -> API Token
TELEGRAM_BOT_TOKEN=123456:REPLACE_WITH_YOUR_BOT_TOKEN

# Twoj Telegram user_id. Zeby go dostac:
# 1) wyslij /start do @userinfobot na Telegramie -> pokaze Ci ID
# 2) lub odpal bota bez whitelist, napisz /start, bot wypisze Twoj id w konsoli
ALLOWED_USER_IDS=123456789

## Turso (te same co w db/.env)
TURSO_DATABASE_URL=libsql://running-graboskov.aws-eu-west-1.turso.io
TURSO_AUTH_TOKEN=REPLACE_WITH_YOUR_TURSO_TOKEN
