# Template. On Streamlit Cloud paste the live values into Settings -> Secrets.
# Locally you can copy this to secrets.toml (gitignored) or rely on db/.env.

TURSO_DATABASE_URL = "libsql://running-<your-org>.aws-eu-west-1.turso.io"
TURSO_AUTH_TOKEN   = "<paste long-lived token from `turso db tokens create running --expiration none`>"

# Password gate. If unset, dashboard is open (fine for localhost). On Streamlit
# Cloud always set it — public URL = anyone who guesses it sees your data.
APP_PASSWORD       = "<choose a strong password>"
